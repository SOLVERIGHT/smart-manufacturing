   "source": [
    "CREATE OR REPLACE VIEW workspace.default.vw_quality_status AS\n",
    "SELECT\n",
    "    equipment_id,\n",
    "    ROUND(quality_rate * 100, 2) AS quality_pct,\n",
    "    CASE\n",
    "        WHEN quality_rate >= 0.98 THEN 'PASS'\n",
    "        ELSE 'FAIL'\n",
    "    END AS status\n",
    "FROM workspace.default.oee_metrics_gold;"
   ]
  }
 ],
